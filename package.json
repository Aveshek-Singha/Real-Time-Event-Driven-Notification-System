{
  "name": "real-time-event-driven-notification-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "node scripts/lint.mjs . && pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "node --test tests/*.test.mjs && pnpm -r test",
    "test:integration": "node --test tests/integration/*.test.mjs",
    "compose:up": "docker compose up -d --wait",
    "compose:down": "docker compose down -v"
  },
  "devDependencies": {
    "@testcontainers/kafka": "^11.5.0",
    "@testcontainers/postgresql": "^11.5.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.16.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
