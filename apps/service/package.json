{
  "name": "@notification-system/service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "node ../../scripts/lint.mjs src package.json tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --conditions=development --import tsx --test src/*.test.ts"
  },
  "dependencies": {
    "@fastify/websocket": "^11.3.0",
    "@notification-system/contracts": "workspace:*",
    "fastify": "^5.0.0",
    "jose": "^6.2.3",
    "kafkajs": "^2.2.4",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0"
  }
}
